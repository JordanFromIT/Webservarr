# ==============================================================================
# HMS Dashboard Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to git (it's in .gitignore)

# ------------------------------------------------------------------------------
# Application Secrets
# ------------------------------------------------------------------------------

# Secret key for FastAPI session signing (generate with: openssl rand -hex 32)
APP_SECRET_KEY=your-secret-key-here

# Authentik secret key (generate with: openssl rand -base64 32)
AUTHENTIK_SECRET_KEY=your-authentik-secret-key-here

# PostgreSQL password for Authentik database
POSTGRES_PASSWORD=your-strong-postgres-password-here

# ------------------------------------------------------------------------------
# Authentik OIDC Configuration
# ------------------------------------------------------------------------------
# These will be generated after setting up Authentik
# Leave blank initially, fill in after configuring Authentik

AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Email Configuration (Optional)
# ------------------------------------------------------------------------------
# Uncomment and configure if you want email notifications

# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-app-specific-password

# ------------------------------------------------------------------------------
# Generation Commands
# ------------------------------------------------------------------------------
# Run these to generate secure secrets:
#
# APP_SECRET_KEY:
#   openssl rand -hex 32
#
# AUTHENTIK_SECRET_KEY:
#   openssl rand -base64 32
#
# POSTGRES_PASSWORD:
#   openssl rand -base64 24
