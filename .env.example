# ==============================================================================
# WebServarr Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env to git (it's in .gitignore).
#
# For most users, no .env file is needed -- the defaults work out of the box.
# A secret key is auto-generated on first startup.

# ------------------------------------------------------------------------------
# Application (Optional)
# ------------------------------------------------------------------------------

# Domain name (set this if using a reverse proxy with a custom domain)
# APP_DOMAIN=dashboard.example.com
# APP_SCHEME=https

# Redis connection string (default works with the bundled Redis container)
# REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# Authentik OIDC (Optional -- only needed if NOT configuring via Settings UI)
# ------------------------------------------------------------------------------
# These can also be configured in Settings > Integrations > Authentik.
# DB settings take priority over environment variables.

# AUTHENTIK_URL=https://auth.example.com
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Authentik Containers (Optional -- only with docker-compose.authentik.yml)
# ------------------------------------------------------------------------------

# AUTHENTIK_SECRET_KEY=your-authentik-secret-key-here
# POSTGRES_PASSWORD=your-strong-postgres-password-here
