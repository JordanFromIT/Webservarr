# =============================================================================
# WebServarr Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Domain and URL (used for CORS and CSP headers)
APP_DOMAIN=localhost
APP_SCHEME=https

# --- Optional: Additional security ---
# Additional CORS origins (comma-separated)
# CORS_ORIGINS=
# Additional CSP frame-src origins (comma-separated, for iframes)
# CSP_FRAME_SRC=
# Additional CSP connect-src origins (comma-separated)
# CSP_CONNECT_SRC=

# --- Optional: Authentik OIDC (see docs/authentik.md) ---
# Required only if deploying Authentik alongside WebServarr
# AUTHENTIK_SECRET_KEY=         # generate with: openssl rand -base64 32
# PG_PASS=                      # any strong password
